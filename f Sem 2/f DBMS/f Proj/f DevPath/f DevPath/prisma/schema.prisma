// DevPath Database Schema
// Based on Entity-Relationship Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== STRONG ENTITIES ====================

/// User entity - represents all registered learners and team members
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  firstName        String
  lastName         String?
  passwordHash     String
  role             String   @default("learner") // 'learner', 'mentor', 'admin'
  subscriptionTier String   @default("starter") // 'starter', 'pro', 'team'
  avatar           String?
  bio              String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  ownedProjects    Project[]
  enrollments      Enrollment[]
  teamMemberships  TeamMember[]
  submissions      Submission[]

  @@map("users")
}

/// Course entity - a structured programming learning track
model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  techStack   String   // Comma-separated tech stack
  difficulty  String   @default("beginner") // 'beginner', 'intermediate', 'advanced'
  duration    Int      // Duration in hours
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lessons     Lesson[]
  enrollments Enrollment[]

  @@map("courses")
}

/// Lesson entity - an individual learning unit within a course
model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String   // Markdown content
  order       Int      // Order within course
  duration    Int      // Duration in minutes
  videoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skillGates    KanbanTask[]
  submissions   LessonSubmission[]
  codeSubmissions Submission[]
  tags          LessonTag[]

  @@unique([courseId, order])
  @@map("lessons")
}

/// LessonTag - multivalued attribute for lesson tags
model LessonTag {
  id       String @id @default(cuid())
  lessonId String
  tag      String

  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, tag])
  @@map("lesson_tags")
}

/// Project entity - a product being built by a user or team
model Project {
  id                 String   @id @default(cuid())
  ownerId            String
  teamId             String?
  name               String
  description        String?
  status             String   @default("planning") // 'planning', 'in_progress', 'completed', 'shipped'
  completionProgress Int      @default(0) // 0-100
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team        Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  kanbanTasks KanbanTask[]
  blueprint   Blueprint?
  teamProjects TeamProject[]

  @@map("projects")
}

/// Team entity - a collaborative group of learners (up to 4 members)
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  maxMembers  Int      @default(4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      TeamMember[]
  projects     Project[]
  teamProjects TeamProject[]

  @@map("teams")
}

/// TeamMember - junction table for M:N User ↔ Team relationship
model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("member") // 'owner', 'member'

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

/// TeamProject - junction table for team-project associations
model TeamProject {
  id        String @id @default(cuid())
  teamId    String
  projectId String

  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([teamId, projectId])
  @@map("team_projects")
}

/// Blueprint entity - AI-generated project blueprint and tech recommendations
model Blueprint {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  techRecommendations String // JSON string of tech recommendations
  architecture       String?  // JSON string of architecture details
  milestones         String?  // JSON string of milestones
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("blueprints")
}

// ==================== WEAK ENTITIES ====================

/// KanbanTask entity - a task card within a project's Kanban board (weak entity)
model KanbanTask {
  id          String   @id @default(cuid())
  projectId   String
  taskName    String
  description String?
  status      String   @default("locked") // 'locked', 'in_progress', 'done', 'review'
  priority    String   @default("medium") // 'low', 'medium', 'high'
  order       Int      @default(0)
  lessonId    String?  // Skill gate - task unlocked after lesson completion
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@unique([projectId, taskName])
  @@map("kanban_tasks")
}

/// Submission entity - a code submission by a user (weak entity)
model Submission {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  code         String
  aiScore      Int?     // 0-100
  aiFeedback   String?  // JSON string of structured feedback
  status       String   @default("pending") // 'pending', 'evaluated', 'passed', 'failed'
  submittedAt  DateTime @default(now())
  evaluatedAt  DateTime?

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

/// LessonSubmission - tracks user progress on lessons
model LessonSubmission {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  status       String   @default("not_started") // 'not_started', 'in_progress', 'completed'
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_submissions")
}

// ==================== JUNCTION TABLES ====================

/// Enrollment - M:N User ↔ Course relationship with grade
model Enrollment {
  id        String    @id @default(cuid())
  userId    String
  courseId  String
  progress  Int       @default(0) // 0-100
  grade     String?   // 'A', 'B', 'C', 'D', 'F'
  enrolledAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}
